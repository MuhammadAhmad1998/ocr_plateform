# Docker Compose defaults — no manual .env copy required.
# Override anything by creating a root .env file (optional).

SECRET_KEY=dev-docker-secret-change-in-production
DEBUG=true
RATE_LIMIT_ENABLED=false

DATABASE_URL=postgresql://postgres:root@postgres:5432/ocr_platform
REDIS_URL=redis://redis:6379/0

USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/app/storage

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Works out of the box without Pinecone or OpenAI keys
USE_MOCK_RAG=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PINECONE_API_KEY=

# Bootstrap super admin (change in production)
SUPER_ADMIN_EMAIL=admin@localhost
SUPER_ADMIN_PASSWORD=admin123

# CPU-only in standard Docker (no NVIDIA runtime required)
VLM_ENABLED=true
VLM_DEVICE=cpu
VLM_EAGER_LOAD=false
PADDLE_OCR_ENABLED=true
PADDLE_OCR_DEVICE=cpu
PADDLE_OCR_EAGER_LOAD=false
QIANFAN_OCR_ENABLED=true
QIANFAN_OCR_DEVICE=cpu
QIANFAN_OCR_EAGER_LOAD=false
GOT_OCR_ENABLED=true
GOT_OCR_DEVICE=cpu
GOT_OCR_EAGER_LOAD=false

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
