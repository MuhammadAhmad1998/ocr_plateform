# Backend
SECRET_KEY=change-me-in-production
# Database (start with: docker compose up -d postgres)
DATABASE_URL=postgresql://ocr:ocr@localhost:5432/ocr_platform
REDIS_URL=redis://localhost:6379/0

# Storage (local dev)
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./storage

# LLM (optional - uses mock advisor without keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Pinecone (optional - uses mock RAG)
PINECONE_API_KEY=
PINECONE_INDEX=ocr-knowledge
USE_MOCK_RAG=true

# Stripe (optional - uses mock checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
