# Backend
SECRET_KEY=change-me-in-production
# Database (local PostgreSQL — run: bash scripts/setup_postgres.sh)
DATABASE_URL=postgresql://ocr:ocr@localhost:5432/ocr_platform
REDIS_URL=redis://localhost:6379/0

# Storage (local dev)
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./storage

# LLM (optional - uses mock advisor without keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Pinecone (optional - uses mock RAG)
PINECONE_API_KEY=
PINECONE_INDEX=ocr-knowledge
USE_MOCK_RAG=true

# Stripe (optional - uses mock checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# VLM (MiniCPM-V)
VLM_ENABLED=true
VLM_MODEL_ID=openbmb/MiniCPM-V-4_5
VLM_ATTN_IMPLEMENTATION=sdpa
VLM_TORCH_DTYPE=bfloat16
VLM_DEVICE=cuda
VLM_PDF_DPI=144
VLM_MAX_PDF_PAGES=50
VLM_EAGER_LOAD=false

# PaddleOCR-VL
PADDLE_OCR_ENABLED=true
PADDLE_OCR_MODEL_ID=PaddlePaddle/PaddleOCR-VL
PADDLE_OCR_TORCH_DTYPE=bfloat16
PADDLE_OCR_DEVICE=cuda
PADDLE_OCR_MAX_NEW_TOKENS=1024
PADDLE_OCR_PDF_DPI=144
PADDLE_OCR_MAX_PDF_PAGES=50
PADDLE_OCR_EAGER_LOAD=false

# Qianfan-OCR
QIANFAN_OCR_ENABLED=true
QIANFAN_OCR_MODEL_ID=baidu/Qianfan-OCR
QIANFAN_OCR_TORCH_DTYPE=bfloat16
QIANFAN_OCR_DEVICE=auto
QIANFAN_OCR_MAX_NEW_TOKENS=512
QIANFAN_OCR_PDF_DPI=144
QIANFAN_OCR_MAX_PDF_PAGES=50
QIANFAN_OCR_EAGER_LOAD=false

# Nanonets OCR 2
NANONETS_OCR_ENABLED=true
NANONETS_OCR_MODEL_ID=nanonets/Nanonets-OCR2-3B
NANONETS_OCR_ATTN_IMPLEMENTATION=flash_attention_2
NANONETS_OCR_TORCH_DTYPE=auto
NANONETS_OCR_DEVICE=auto
NANONETS_OCR_MAX_NEW_TOKENS=4096
NANONETS_OCR_PDF_DPI=144
NANONETS_OCR_MAX_PDF_PAGES=50
NANONETS_OCR_EAGER_LOAD=false

# Model Memory Management
# Automatically unload previous model when switching to a different model
# This prevents CUDA out of memory errors when GPU VRAM is limited
AUTO_UNLOAD_MODELS=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
